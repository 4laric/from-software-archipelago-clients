//! Pure AP contract-version gate, extracted from the Windows-gated `net.rs`.
//!
//! Faithful to `net.rs`: a REJECT is a non-fatal WARN (the connection is NOT torn down); an absent
//! `versions` key means the gate is inert and the connection proceeds (older seeds).

use serde_json::Value;

/// Decide whether the slot_data `versions` range accepts `our_version`.
///
///  - `None`        — no `versions` key in slot_data (older seed): gate inert, connect proceeds.
///  - `Some(true)`  — range accepts our version.
///  - `Some(false)` — range rejects our version: `net.rs` logs the "update one side" warning
///   (it does NOT disconnect).
pub fn version_gate(slot_data: &Value, our_version: &str) -> Option<bool> {
    slot_data
        .get("versions")
        .and_then(|v| v.as_str())
        .map(|range| er_semver::version_satisfies(our_version, range).unwrap_or(false))
}

#[cfg(test)]
mod tests {
    use super::*;
    use serde_json::json;

    #[test]
    fn band_accepts_member_version() {
        // The "apworld requires 0.6.6" framing: a 0.6.x band accepts a 0.6.6 client.
        let sd = json!({ "versions": ">=0.6.6 <0.7.0" });
        assert_eq!(version_gate(&sd, "0.6.6"), Some(true));
    }

    #[test]
    fn band_rejects_below_and_at_exclusive_upper_bound() {
        let sd = json!({ "versions": ">=0.6.6 <0.7.0" });
        assert_eq!(version_gate(&sd, "0.6.5"), Some(false));
        assert_eq!(version_gate(&sd, "0.7.0"), Some(false));
    }

    #[test]
    fn absent_versions_key_is_inert() {
        // No versions key -> None -> net.rs skips the check and connects (older seed).
        let sd = json!({ "seed": "abc" });
        assert_eq!(version_gate(&sd, "0.6.6"), None);
    }

    #[test]
    fn unparseable_range_rejects_not_panics() {
        // version_satisfies(..).unwrap_or(false): a garbage range is Some(false), never a panic.
        let sd = json!({ "versions": "not-a-range" });
        assert_eq!(version_gate(&sd, "0.6.6"), Some(false));
    }
}
